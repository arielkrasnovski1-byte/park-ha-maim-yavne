rules_version = '2';

// ============================================================
// Cloud Storage Security Rules — Park HaMayim Yavne
// ------------------------------------------------------------
//   * Gallery images are world-readable (they appear on the site).
//   * Upload/delete is allowed ONLY for admins — resolved against the
//     same Firestore /admins allowlist used by the Firestore rules
//     (via firestore.exists). This needs the Storage service account
//     to have Firestore access ("Attach permissions" in the console).
//   * Only real images up to 10MB.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /gallery/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
