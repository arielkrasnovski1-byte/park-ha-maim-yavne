{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "redirects": [
      { "source": "/index.php", "destination": "/", "type": 301 },
      { "source": "/index.php/**", "destination": "/", "type": 301 }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "*.md",
      "firestore.rules",
      "storage.rules",
      "preview-*.html",
      "_*.html",
      "פארק-המים-יבנה-מצגת-האתר.pdf",
      "new images/**",
      "pdf-output/**"
    ]
  }
}
