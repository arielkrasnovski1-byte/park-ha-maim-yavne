rules_version = '2';

// ============================================================
// Firestore Security Rules — Park HaMayim Yavne
// ------------------------------------------------------------
// Same structure as before, with ONE change: "write" now requires
// isAdmin() instead of just being signed in. Being logged in is no
// longer enough — the user's UID must exist under /admins.
//
// Add an admin:  Authentication > Add user > copy the UID >
//                Firestore > create doc  admins/<that-uid>.
// Remove access: delete that doc (or the user).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // הודעות נכנסות מטופס: רק יצירה, רק אדמין רואה/מנהל
    match /messages/{msg} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // מיילים יוצאים (תוסף Trigger Email): רק יצירה דרך הטופס.
    // הערה: create פתוח = סיכון spam-relay; תיקון מלא = Cloud Function.
    match /mail/{m} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // שאר התוכן: קריאה ציבורית, כתיבה רק לאדמינים מורשים
    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
